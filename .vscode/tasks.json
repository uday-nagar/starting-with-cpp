{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile and run",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/C",
                "g++ -std=c++17 -o ${fileBasenameNoExtension}.exe ${fileBasenameNoExtension}.cpp && .\\${fileBasenameNoExtension}.exe < input.txt > output.txt"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${fileDirname}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
